    "端口必须在 1-65535 之间。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Port must be between 1 and 65535."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "端口必须在 1-65535 之间。"
          }
        }
      }
    },
    "地址必须以 http:// 或 https:// 开头。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "URL must start with http:// or https://."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "地址必须以 http:// 或 https:// 开头。"
          }
        }
      }
    },
    "超时时间必须在 1-3600 秒之间。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Timeout must be between 1 and 3600 seconds."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "超时时间必须在 1-3600 秒之间。"
          }
        }
      }
    },
    "重试次数必须在 0-10 之间。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Retries must be between 0 and 10."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重试次数必须在 0-10 之间。"
          }
        }
      }
    },
    "重试延迟必须在 0-600000 毫秒之间。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Retry delay must be between 0 and 600000 ms."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重试延迟必须在 0-600000 毫秒之间。"
          }
        }
      }
    },
    "OneBot 超时必须在 1-600 秒之间。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OneBot timeout must be between 1 and 600 seconds."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "OneBot 超时必须在 1-600 秒之间。"
          }
        }
      }
    },
    "群聊历史条数必须是 0 或正整数。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Group history size must be 0 or a positive integer."
